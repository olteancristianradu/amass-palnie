# Copiază în `.env` (lângă docker-compose.yml) și completează. NU urca .env în git.
# Generează secretele cu:  openssl rand -base64 32

NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=schimba_cu_openssl_rand_base64_32
CRYPTO_KEY=schimba_cu_openssl_rand_base64_32

# Opțional — trimitere devize prin Outlook (lasă gol dacă nu folosești)
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
